# Postgres connection string — must be a READ-ONLY role
# Never use an admin/write role here
DATABASE_URL=postgresql://cascade_readonly:readonly_secret@localhost:5432/cascade_map

# API server port
PORT=3001

# CORS — set to your frontend URL in production
CORS_ORIGIN=http://localhost:5173

# Cascade traversal limits (tune these, do not hardcode in source)
MAX_TRAVERSAL_DEPTH=5
MAX_ROWS_PER_TABLE=500
